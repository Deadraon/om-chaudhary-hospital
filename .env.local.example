# ============================================
# Om Chaudhary Hospital — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# Cloudflare Account
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Cloudflare D1 Database
D1_DATABASE_ID=your_d1_database_id

# Cloudflare R2 Bucket
R2_BUCKET_NAME=hospital-files
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Cloudflare KV Namespace
KV_NAMESPACE_ID=your_kv_namespace_id

# JWT Secret (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Fast2SMS API
FAST2SMS_API_KEY=your_fast2sms_api_key

# Public variables
NEXT_PUBLIC_HOSPITAL_NAME="Om Chaudhary Hospital & Trauma Centre"
NEXT_PUBLIC_EMERGENCY_NUMBER="108"
NEXT_PUBLIC_HOSPITAL_PHONE="+91-XXXXXXXXXX"
NEXT_PUBLIC_HOSPITAL_EMAIL="info@omchaudharyhospital.com"
NEXT_PUBLIC_HOSPITAL_ADDRESS="Om Chaudhary Hospital & Trauma Centre, Main Road, City, State, India"
